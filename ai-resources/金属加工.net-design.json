    "Bold Text": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Meiryo",
        "fontSize": "14px",
        "fontWeight": 700,
        "lineHeight": "17.5px",
        "letterSpacing": "normal"
      },
      "$description": "Emphasized text and important information"
    }
